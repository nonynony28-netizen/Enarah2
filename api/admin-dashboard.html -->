<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>لوحة التحكم</title>

  <style>
    body {
      margin: 0;
      font-family: Arial;
      background: #06152b;
      color: white;
      padding: 20px;
    }

    h1 {
      text-align: center;
    }

    .grid {
      display: grid;
      gap: 20px;
    }

    .card {
      background: #0b1d39;
      padding: 15px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.08);
    }

    img {
      width: 100%;
      max-height: 250px;
      object-fit: cover;
      border-radius: 10px;
    }

    button {
      margin-top: 10px;
      width: 100%;
      padding: 12px;
      border: none;
      border-radius: 10px;
      background: red;
      color: white;
      cursor: pointer;
    }
  </style>
</head>
<body>

  <h1>لوحة التحكم</h1>

  <div id="items" class="grid">
    جاري التحميل...
  </div>

  <script>
    async function loadItems() {
      const container =
        document.getElementById("items");

      try {
        const res = await fetch(
          "/api/get-users"
        );

        const data = await res.json();

        if (!data.success) {
          container.innerHTML =
            "فشل تحميل البيانات";
          return;
        }

        container.innerHTML = "";

        data.data.forEach(item => {
          let media = {};

          try {
            media = item.phone
              ? JSON.parse(item.phone)
              : {};
          } catch {}

          const card =
            document.createElement("div");

          card.className = "card";

          card.innerHTML = `
            ${
              media.imageUrl
                ? `<img src="${media.imageUrl}" />`
                : ""
            }

            <h3>${item.name || "بدون اسم"}</h3>

            <p>${
              item.email &&
              !item.email.includes("@upload.local")
                ? item.email
                : ""
            }</p>

            <button onclick="deleteItem('${item._id}')">
              حذف
            </button>
          `;

          container.appendChild(card);
        });
      } catch {
        container.innerHTML =
          "حدث خطأ أثناء التحميل";
      }
    }

    async function deleteItem(id) {
      if (!confirm("هل أنت متأكد من الحذف؟")) {
        return;
      }

      try {
        const res = await fetch(
          "/api/delete-user",
          {
            method: "DELETE",
            headers: {
              "Content-Type":
                "application/json",
            },
            body: JSON.stringify({
              id,
            }),
          }
        );

        const data =
          await res.json();

        if (data.success) {
          alert("تم الحذف بنجاح");
          loadItems();
        } else {
          alert(
            data.error ||
            "فشل الحذف"
          );
        }
      } catch {
        alert(
          "حدث خطأ أثناء الحذف"
        );
      }
    }

    loadItems();
  </script>

</body>
</html>
